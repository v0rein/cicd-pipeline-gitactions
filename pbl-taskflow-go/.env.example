# Environment variables untuk TaskFlow API
# Salin file ini: cp .env.example .env
# Kemudian sesuaikan nilai di .env (jangan di-commit ke git!)

# ── Database ────────────────────────────────────────────────────────────────
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://taskflow:taskflow_secret@localhost:5432/taskflow?sslmode=disable

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ── Catatan untuk pipeline CI ───────────────────────────────────────────────
# Untuk integration test, set DATABASE_URL ke postgres service container:
# DATABASE_URL=postgres://taskflow:taskflow_secret@localhost:5432/taskflow?sslmode=disable
